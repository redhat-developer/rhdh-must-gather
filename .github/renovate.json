{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranchPatterns": ["main", "/^release-.*/"],
  "pip-compile": {
    "enabled": true,
    "managerFilePatterns": [".rhdh/docker/requirements*.txt"]
  },
  "pip_requirements": {
    "enabled": false
  },
  "packageRules": [
    {
      "description": "yq is tracked via the Makefile custom manager; ignore it in pip-compile",
      "matchManagers": ["pip-compile"],
      "matchPackageNames": ["yq"],
      "enabled": false
    },
    {
      "description": "Only allow patch updates on release branches",
      "matchBaseBranches": ["/^release-.*/"],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    }
  ],
  "customDatasources": {
    "openshift-client": {
      "defaultRegistryUrlTemplate": "https://mirror.openshift.com/pub/openshift-v4/clients/ocp/",
      "format": "html",
      "transformTemplates": [
        "{\"releases\": [$filter($, function($v){$type($v)=\"string\" and $contains($v, /^4\\.\\d+\\.\\d+\\/$/)}).( {\"version\": $replace($, /\\/$/, \"\")} )]}"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=npm\\n\\s*npm install\\s+--no-save\\s+(?<depName>[^@\\s]+)@(?<currentValue>[\\d.]+)"
      ],
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Containerfile$/"],
      "matchStrings": [
        "https://get\\.helm\\.sh/helm-(?<currentValue>v[\\d.]+)-linux-amd64\\.tar\\.gz"
      ],
      "depNameTemplate": "helm/helm",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Containerfile$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=custom\\.openshift-client\\nRUN curl.*ocp/(?<currentValue>[\\d.]+)/openshift-client"
      ],
      "depNameTemplate": "openshift-client",
      "datasourceTemplate": "custom.openshift-client"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=pypi\\s+depName=(?<depName>\\S+)\\nYQ_VERSION := (?<currentValue>[\\d.]+)"
      ],
      "datasourceTemplate": "pypi"
    }
  ]
}
