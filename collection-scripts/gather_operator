#!/usr/bin/env bash

# Operator Data Collection Script
# Collects Operator-specific information for RHDH deployments

set -euo pipefail

# Get script directory for calling other scripts
DIR_NAME=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
source "${DIR_NAME}/common.sh"

log_info "Starting Operator data collection..."

operator_dir="$BASE_COLLECTION_PATH/operator"
ensure_directory "$operator_dir"

function gather_olm_information() {
    log_info "Collecting OLM (Operator Lifecycle Manager) information..."

    local olm_dir="$operator_dir/olm"
    ensure_directory "$olm_dir"

    namespace_args=$(get_namespace_args)
    
    # ClusterServiceVersions
    if [[ -n "${RHDH_TARGET_NAMESPACES:-}" ]]; then
        safe_exec "$KUBECTL_CMD get csv $namespace_args | grep -E '(rhdh|backstage|developer-hub)'" "$olm_dir/rhdh-csv-all.txt" "RHDH CSVs in specified namespaces"
        safe_exec "$KUBECTL_CMD get subscription $namespace_args | grep -E '(rhdh|backstage|developer-hub)'" "$olm_dir/rhdh-subscriptions-all.txt" "RHDH subscriptions in specified namespaces"
        safe_exec "$KUBECTL_CMD get installplan $namespace_args" "$olm_dir/installplans-all.txt" "InstallPlans in specified namespaces"
        safe_exec "$KUBECTL_CMD get operatorgroup $namespace_args" "$olm_dir/operatorgroups-all.txt" "OperatorGroups in specified namespaces"
        safe_exec "$KUBECTL_CMD get catalogsource $namespace_args" "$olm_dir/catalogsources-all.txt" "CatalogSources in specified namespaces"
    else
        safe_exec "$KUBECTL_CMD get csv --all-namespaces | grep -E '(rhdh|backstage|developer-hub)'" "$olm_dir/rhdh-csv-all.txt" "RHDH CSVs in all namespaces"
        safe_exec "$KUBECTL_CMD get subscription --all-namespaces | grep -E '(rhdh|backstage|developer-hub)'" "$olm_dir/rhdh-subscriptions-all.txt" "RHDH subscriptions in all namespaces"
        safe_exec "$KUBECTL_CMD get installplan --all-namespaces" "$olm_dir/installplans-all.txt" "InstallPlans in all namespaces"
        safe_exec "$KUBECTL_CMD get operatorgroup --all-namespaces" "$olm_dir/operatorgroups-all.txt" "OperatorGroups in all namespaces"
        safe_exec "$KUBECTL_CMD get catalogsource --all-namespaces" "$olm_dir/catalogsources-all.txt" "CatalogSources in all namespaces"
    fi
}

function gather_crds() {
  log_info "\tCollecting RHDH-related Custom Resource Definitions..."

  local crds_dir="$operator_dir/crds"
  ensure_directory "$crds_dir"

  # RHDH/Backstage CRDs
  safe_exec "$KUBECTL_CMD get crd" "$crds_dir/all-crds.txt" "All CRDs in cluster"

  # Specific RHDH CRDs
  local rhdh_crds=(
      "backstages.rhdh.redhat.com"
  )

  for crd in "${rhdh_crds[@]}"; do
      if $KUBECTL_CMD get crd "$crd" >/dev/null 2>&1; then
          safe_exec "$KUBECTL_CMD get crd '$crd' -o yaml" "$crds_dir/${crd}.yaml" "CRD definition for $crd"
          safe_exec "$KUBECTL_CMD describe crd '$crd'" "$crds_dir/${crd}.describe.txt" "CRD description for $crd"
      else
          echo "CRD $crd not found" > "$crds_dir/${crd}--not-found.txt"
      fi
  done
}

function gather_operator_config() {
  local dir=$1
  local ns=$2
  log_info "\tCollecting all Operator config ConfigMaps in $ns..."

  local configs_dir="$dir/configs"
  ensure_directory "$configs_dir"

  safe_exec "$KUBECTL_CMD get configmap -n $ns" "$configs_dir/all-configmaps.txt" "All ConfigMaps in $ns"

  local rhdh_cms=(
      "rhdh-default-config"
      "rhdh-plugin-deps"
  )

  for cm in "${rhdh_cms[@]}"; do
        if $KUBECTL_CMD -n "$ns" get configmap "$cm" >/dev/null 2>&1; then
            safe_exec "$KUBECTL_CMD -n $ns get configmap '$cm' -o yaml" "$configs_dir/${cm}.yaml" "CM definition for $cm"
            safe_exec "$KUBECTL_CMD -n $ns describe configmap '$cm'" "$configs_dir/${cm}.describe.txt" "CM description for $cm"
        else
            echo "CM $cm not found" > "$configs_dir/${cm}--not-found.txt"
        fi
  done
}

function gather_deployments() {
  local dir=$1
  local ns=$2
  log_info "\tCollecting Operator Deployments in $ns..."

  local deployments_dir="$dir/deployments"
  ensure_directory "$deployments_dir"

  safe_exec "$KUBECTL_CMD get deployments -n $ns" "$deployments_dir/all-deployments.txt" "All Deployments in $ns"

  safe_exec "$KUBECTL_CMD get deployments -n $ns -l app=rhdh-operator -o yaml" "$deployments_dir/app=rhdh-operator.yaml" \
    "Deployments with label app=rhdh-operator $ns"

  safe_exec "$KUBECTL_CMD describe deployments -n $ns -l app=rhdh-operator" "$deployments_dir/app=rhdh-operator.describe.txt" \
    "Deployment description with label app=rhdh-operator in $ns"
}

function gather_operator_logs() {
  local dir=$1
  local ns=$2
  log_info "\tCollecting Operator Logs in $ns..."

  safe_exec "$KUBECTL_CMD -n $ns logs -l app=rhdh-operator --all-containers --prefix ${log_collection_args:-}" "$dir/logs.txt" \
    "Logs of pods with label app=rhdh-operator in $ns"
  safe_exec "$KUBECTL_CMD -n $ns logs -l app=rhdh-operator --all-containers --prefix --previous ${log_collection_args:-}" "$dir/logs-previous.txt" \
    "Logs (previous) of pods with label app=rhdh-operator in $ns"
}

function gather_backstage_crs() {
  log_info "Searching for Backstage Custom Resources (CRs) in all or target namespaces..."

  crs_dir="$operator_dir/backstage-crs"
  ensure_directory "$crs_dir"

  # Do not rely on "get crd" here: the user may lack permission to list CRDs but may have
  # permission to "get backstages.rhdh.redhat.com" in their namespace(s). Proceed to list CRs.
  namespace_args=$(get_namespace_args)
  safe_exec "$KUBECTL_CMD get backstages.rhdh.redhat.com $namespace_args" "$crs_dir/all-backstage-crs.txt" \
    "All Backstage CRs in $namespace_args"

  # Get JSON output and store in temp file, only parse if it's valid JSON
  local json_output
  # shellcheck disable=SC2086 # namespace_args may contain multiple arguments, word splitting is intentional
  json_output=$($KUBECTL_CMD get backstages.rhdh.redhat.com $namespace_args -o json 2>/dev/null || echo "")
  
  crs=""
  cr_namespaces=""
  if [[ -n "$json_output" ]] && echo "$json_output" | jq -e '.items' >/dev/null 2>&1; then
      crs=$(echo "$json_output" | jq -r '.items[] | "\(.metadata.namespace)/\(.metadata.name)"' 2>/dev/null || echo "")
      cr_namespaces=$(echo "$json_output" | jq -r '.items[].metadata.namespace' 2>/dev/null | sort | uniq || echo "")
  fi

  if [[ -z "$crs" ]]; then
      log_warn "No Backstage CR found"
      echo "No Backstage CR found" > "$crs_dir/no-crs.txt"
      return 0
  fi

  log_debug "cr_namespaces: $cr_namespaces"
  log_debug "crs: $crs"

  # Process each namespace
  for cr_ns in $cr_namespaces; do
    log_info "--> Processing namespace $cr_ns containing at least one Backstage CR"

    cr_ns_dir="$crs_dir/ns=$cr_ns/"
    ensure_directory "$cr_ns_dir"

    collect_namespace_data "$cr_ns" "$cr_ns_dir"
  done

  # Process each cr
  for cr_info in $crs; do
      if [[ -z "$cr_info" ]]; then
          continue
      fi

      cr_ns=""
      cr_name="$cr_info"

      # Handle namespace/cr format from all-namespaces search
      if [[ "$cr_info" == *"/"* ]]; then
          cr_ns=$(echo "$cr_info" | cut -d'/' -f1)
          cr_name=$(echo "$cr_info" | cut -d'/' -f2)
      fi

      log_info "--> Processing Backstage CR $cr_name in namespace $cr_ns"

      cr_dir="$crs_dir/ns=$cr_ns/$cr_name"
      ensure_directory "$cr_dir"

      safe_exec "$KUBECTL_CMD -n '$cr_ns' get backstages.rhdh.redhat.com '$cr_name' -o yaml" "$cr_dir/$cr_name.yaml" "Details of CR $cr_name"

      safe_exec "$KUBECTL_CMD -n '$cr_ns' describe backstages.rhdh.redhat.com '$cr_name'" "$cr_dir/describe.txt" "Details of CR $cr_name"

      # Collect app-specific info (pass CR name for heap dump filtering)
      deploy="backstage-$cr_name"
      statefulset="backstage-psql-$cr_name"

      # Detect dual workload: both a Deployment and StatefulSet with the same name.
      # This happens when spec.deployment.kind is changed in the Backstage CR
      # (RHDH Operator 1.9+), and the previous workload was not cleaned up.
      local has_deploy has_sts
      has_deploy=$($KUBECTL_CMD -n "$cr_ns" get deployment "$deploy" -o name 2>/dev/null || true)
      has_sts=$($KUBECTL_CMD -n "$cr_ns" get statefulset "$deploy" -o name 2>/dev/null || true)

      if [[ -n "$has_deploy" ]] && [[ -n "$has_sts" ]]; then
          local intended_kind
          intended_kind=$($KUBECTL_CMD -n "$cr_ns" get backstages.rhdh.redhat.com "$cr_name" \
              -o jsonpath='{.spec.deployment.kind}' 2>/dev/null || echo "")

          local leftover_kind
          if [[ "$intended_kind" == "StatefulSet" ]]; then
              leftover_kind="Deployment"
          else
              leftover_kind="StatefulSet"
          fi

          log_warn "Both a Deployment and a StatefulSet named '$deploy' exist in namespace '$cr_ns'."
          log_warn "This may indicate a workload type migration where the previous $leftover_kind was not cleaned up."
          if [[ -n "$intended_kind" ]]; then
              log_warn "The Backstage CR spec.deployment.kind is set to '$intended_kind'."
          fi

          cat > "$cr_dir/warning-dual-workload.txt" << WARN_EOF
WARNING: Duplicate RHDH workloads detected

Both a Deployment and a StatefulSet named '$deploy' were found in namespace '$cr_ns'.

This typically happens when the Backstage CR's spec.deployment.kind field is changed
(e.g., from Deployment to StatefulSet), causing the RHDH Operator to create a new
workload of the desired type while the previous one remains running, as it is no
longer managed by the Operator.

$(if [[ -n "$intended_kind" ]]; then
echo "The Backstage CR spec.deployment.kind is currently set to: $intended_kind"
echo "This means the $leftover_kind is likely a leftover that should be manually deleted."
else
echo "The Backstage CR spec.deployment.kind is not set (defaults to Deployment)."
echo "This means the StatefulSet may be a leftover that should be manually deleted."
fi)

Recommended action:
  Delete the leftover $(echo "$leftover_kind" | tr '[:upper:]' '[:lower:]') that is no longer managed by the Operator:
    kubectl -n $cr_ns delete $(echo "$leftover_kind" | tr '[:upper:]' '[:lower:]') $deploy

Refer to the RHDH Operator documentation for more details on workload type migration.

Collected data:
  - deployment/          contains the Deployment workload data
  - rhdh-statefulset/    contains the StatefulSet workload data
  - db-statefulset/      contains the database StatefulSet data (if applicable)
WARN_EOF

          collect_rhdh_workload "$cr_ns" "$deploy" "deployment" "$cr_dir/deployment" "$cr_name"
          collect_rhdh_workload "$cr_ns" "$deploy" "statefulset" "$cr_dir/rhdh-statefulset" "$cr_name"
      else
          # Determine which workload kind exists
          local workload_kind="deployment"
          if [[ -z "$has_deploy" ]] && [[ -n "$has_sts" ]]; then
              workload_kind="statefulset"
          fi
          collect_rhdh_workload "$cr_ns" "$deploy" "$workload_kind" "$cr_dir/deployment" "$cr_name"
      fi

      collect_rhdh_db_statefulset "$cr_ns" "$statefulset" "$cr_dir"
  done
}

gather_olm_information
gather_crds

namespace_args=$(get_namespace_args)
safe_exec "$KUBECTL_CMD get deployments $namespace_args -l app=rhdh-operator" "$operator_dir/all-deployments.txt" "All RHDH Operator Deployments"

operatorNamespaces=$($KUBECTL_CMD get deployments "$namespace_args" -l app=rhdh-operator -o jsonpath="{.items[*].metadata.namespace}" 2>/dev/null || true)
log_info "Found Operator namespaces: $operatorNamespaces"

for operatorNamespace in $operatorNamespaces; do
  # Skip this namespace if namespace filtering is enabled and it's not in the target list
  if ! should_include_namespace "$operatorNamespace"; then
    log_debug "Skipping operator namespace $operatorNamespace (not in target list)"
    continue
  fi

  operator_ns_dir="$operator_dir/ns=$operatorNamespace"
  ensure_directory "$operator_ns_dir"

  safe_exec "$KUBECTL_CMD get all -n \"${operatorNamespace}\"" "$operator_ns_dir/all-resources.txt" "All resources in $operatorNamespace"

  gather_operator_config "$operator_ns_dir" "$operatorNamespace"
  gather_deployments "$operator_ns_dir" "$operatorNamespace"
  gather_operator_logs "$operator_ns_dir" "$operatorNamespace"
done

gather_backstage_crs

log_success "... Operator data collection done."
